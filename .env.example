# Copy to .env on the server (chmod 600). Plain KEY=value lines — no quotes,
# no `export`. Loaded by systemd via EnvironmentFile=.

# Smartsheet API token (server-side only; never sent to the browser)
SMARTSHEET_TOKEN=

# Secret used to sign login sessions (JWT). Generate a long random string, e.g.:
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
JWT_SECRET=

# User store — Upstash Redis REST (free tier works from any server).
# Create a database at https://console.upstash.com and copy the REST URL + token.
KV_REST_API_URL=
KV_REST_API_TOKEN=

# Local bind (Nginx proxies to this). Defaults are fine.
PORT=3000
HOST=127.0.0.1
